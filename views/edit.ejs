<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Page</title>
</head>
<body>

    <h1>You Can Edit the Page of <%= user.email %></h1>
    

    <form method="post" action="/users/<%= user.id %>?_method=PATCH">
        <textarea name="username" rows="5" cols="20"> <%= user.username %> </textarea><br><br>
        <input type="password" name="password" placeholder="Enter Password"><br><br><br>
        <button>Edit</button>
    </form>
    
</body>
</html>